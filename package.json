<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chategle - Habla con extraños</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f0f0f0;
    --panel-bg: #ffffff;
    --header-bg: #1a1a2e;
    --accent: #e94560;
    --accent2: #0f3460;
    --text: #222;
    --text-muted: #888;
    --border: #ddd;
    --msg-you: #dff0d8;
    --msg-stranger: #ffffff;
    --msg-system: #fff3cd;
    --shadow: 0 2px 12px rgba(0,0,0,0.10);
    --radius: 6px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Nunito', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; flex-direction: column; }

  header { background: var(--header-bg); padding: 0 20px; display: flex; align-items: center; justify-content: space-between; height: 52px; box-shadow: 0 2px 8px rgba(0,0,0,0.3); }
  .logo { font-size: 1.6rem; font-weight: 800; color: #fff; letter-spacing: -1px; }
  .logo span { color: var(--accent); }
  nav a { color: #ccc; text-decoration: none; font-size: 0.85rem; margin-left: 18px; font-weight: 600; }

  main { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 18px 12px 12px; gap: 12px; }
  .tagline { text-align: center; font-size: 0.92rem; color: #444; max-width: 560px; }
  .tagline strong { color: var(--accent2); }

  .interests-bar { background: var(--panel-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 8px 14px; display: flex; align-items: center; gap: 8px; width: 100%; max-width: 800px; box-shadow: var(--shadow); flex-wrap: wrap; }
  .interests-bar label { font-size: 0.82rem; font-weight: 700; color: #555; white-space: nowrap; }
  .interests-bar input { flex: 1; border: none; outline: none; font-family: inherit; font-size: 0.85rem; min-width: 120px; }
  .tag { background: #e8f0fe; color: #1a73e8; border-radius: 12px; padding: 2px 10px; font-size: 0.78rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 4px; }
  .tag .x { color: #999; font-size: 0.9rem; margin-left: 2px; }

  .chat-area { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; width: 100%; max-width: 900px; }
  .chat-panel { background: var(--panel-bg); border: 1px solid var(--border); border-radius: var(--radius); display: flex; flex-direction: column; box-shadow: var(--shadow); min-height: 380px; overflow: hidden; }
  .panel-header { background: var(--header-bg); color: #fff; padding: 8px 14px; font-size: 0.82rem; font-weight: 700; display: flex; align-items: center; gap: 6px; }
  .panel-header .dot { width: 8px; height: 8px; border-radius: 50%; background: #aaa; display: inline-block; }
  .panel-header .dot.online { background: #4CAF50; box-shadow: 0 0 4px #4CAF50; }

  .messages { flex: 1; overflow-y: auto; padding: 10px 12px; display: flex; flex-direction: column; gap: 6px; background: #fafafa; }
  .messages::-webkit-scrollbar { width: 4px; }
  .messages::-webkit-scrollbar-thumb { background: #ccc; border-radius: 2px; }

  .msg { max-width: 92%; padding: 7px 12px; border-radius: 6px; font-size: 0.88rem; line-height: 1.45; word-break: break-word; animation: fadeIn 0.2s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; } }
  .msg.you { background: var(--msg-you); align-self: flex-end; border-bottom-right-radius: 2px; }
  .msg.stranger { background: var(--msg-stranger); border: 1px solid #e0e0e0; align-self: flex-start; border-bottom-left-radius: 2px; }
  .msg.system { background: var(--msg-system); border: 1px solid #ffe082; align-self: center; font-style: italic; color: #7a6000; font-size: 0.8rem; text-align: center; border-radius: 12px; padding: 4px 14px; }
  .msg-label { font-size: 0.72rem; font-weight: 800; color: var(--accent2); margin-bottom: 1px; }
  .msg.you .msg-label { color: #388e3c; text-align: right; }

  .input-row { display: flex; border-top: 1px solid var(--border); background: #fff; }
  textarea.msg-input { flex: 1; border: none; outline: none; resize: none; padding: 10px 12px; font-family: inherit; font-size: 0.88rem; height: 68px; background: transparent; }
  .send-btn { background: var(--accent2); color: #fff; border: none; padding: 0 18px; cursor: pointer; font-family: inherit; font-weight: 700; font-size: 0.85rem; border-left: 1px solid var(--border); transition: background 0.2s; }
  .send-btn:hover { background: #0d2b4e; }
  .send-btn:disabled, textarea:disabled { opacity: 0.5; cursor: default; }

  .typing-indicator { font-size: 0.78rem; color: #888; font-style: italic; padding: 4px 12px; min-height: 20px; background: #fafafa; border-top: 1px solid #f0f0f0; }

  .controls { display: flex; gap: 10px; width: 100%; max-width: 900px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .btn { padding: 10px 30px; border: none; border-radius: var(--radius); font-family: inherit; font-weight: 800; font-size: 1rem; cursor: pointer; transition: background 0.2s, transform 0.1s; }
  .btn:active { transform: scale(0.97); }
  .btn-start { background: #4CAF50; color: #fff; }
  .btn-start:hover { background: #43a047; }
  .btn-stop { background: #f44336; color: #fff; }
  .btn-stop:hover { background: #e53935; }
  .btn:disabled { opacity: 0.5; cursor: default; }

  .status-bar { font-size: 0.8rem; color: var(--text-muted); text-align: center; }
  .status-bar strong { color: var(--accent2); }

  footer { background: var(--header-bg); color: #aaa; text-align: center; font-size: 0.75rem; padding: 10px; }

  /* Overlay disclaimer */
  .overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.55); display: flex; align-items: center; justify-content: center; z-index: 100; }
  .modal { background: #fff; border-radius: 10px; padding: 32px 30px; max-width: 420px; width: 92%; box-shadow: 0 8px 40px rgba(0,0,0,0.25); text-align: center; }
  .modal h2 { font-size: 1.5rem; margin-bottom: 10px; color: var(--header-bg); }
  .modal p { font-size: 0.88rem; color: #555; line-height: 1.6; margin-bottom: 18px; }

  @media (max-width: 600px) {
    .chat-area { grid-template-columns: 1fr; }
    .btn { padding: 10px 18px; font-size: 0.9rem; }
  }
</style>
</head>
<body>

<div class="overlay" id="overlay">
  <div class="modal">
    <h2>⚠️ Aviso</h2>
    <p>Al usar este sitio aceptas ser <strong>respetuoso</strong> con los demás usuarios. No compartas datos personales. El uso inapropiado puede resultar en bloqueo.</p>
    <button class="btn btn-start" style="width:100%;font-size:1rem;" onclick="document.getElementById('overlay').style.display='none'">Entendido, Continuar</button>
  </div>
</div>

<header>
  <div class="logo">Chat<span>egle</span></div>
  <nav>
    <a href="#">Inicio</a>
    <a href="#">Reglas</a>
  </nav>
</header>

<main>
  <p class="tagline">Habla con <strong>personas reales</strong> de todo el mundo. Solo texto, sin registro.</p>

  <div class="interests-bar">
    <label>¿Qué te interesa?</label>
    <input type="text" id="interestInput" placeholder="Añade un interés y presiona Enter..." onkeydown="addInterest(event)">
    <div id="tagsContainer" style="display:flex;gap:6px;flex-wrap:wrap;"></div>
  </div>

  <div class="chat-area">
    <!-- Panel extraño -->
    <div class="chat-panel">
      <div class="panel-header">
        <span class="dot" id="strangerDot"></span>
        <span id="strangerLabel">Extraño</span>
      </div>
      <div class="messages" id="strangerMessages">
        <div class="msg system">Haz clic en "Nuevo chat" para conectarte.</div>
      </div>
      <div class="typing-indicator" id="typingIndicator"></div>
    </div>

    <!-- Panel tuyo -->
    <div class="chat-panel">
      <div class="panel-header">
        <span class="dot online"></span>
        <span>Tú</span>
      </div>
      <div class="messages" id="yourMessages">
        <div class="msg system">Tus mensajes aparecerán aquí.</div>
      </div>
      <div class="input-row">
        <textarea class="msg-input" id="msgInput" placeholder="Escribe un mensaje..." disabled onkeydown="handleKey(event)" oninput="onTyping()"></textarea>
        <button class="send-btn" id="sendBtn" onclick="sendMessage()" disabled>Enviar</button>
      </div>
    </div>
  </div>

  <div class="controls">
    <button class="btn btn-start" id="startBtn" onclick="startChat()">Nuevo chat</button>
    <button class="btn btn-stop" id="stopBtn" onclick="leaveChat()" disabled>Desconectar</button>
  </div>
  <div class="status-bar">Usuarios conectados ahora: <strong id="onlineCount">--</strong></div>
</main>

<footer>Chategle &copy; 2024 — Úsalo con respeto.</footer>

<!-- Socket.io cliente (se carga automáticamente desde el servidor) -->
<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();

  let chatActive = false;
  let typingTimer = null;

  // Online count
  socket.on('onlineCount', count => {
    document.getElementById('onlineCount').textContent = count.toLocaleString();
  });

  // Esperando pareja
  socket.on('waiting', () => {
    addSystemMsg('strangerMessages', 'Buscando a alguien con quien hablar...');
    addSystemMsg('yourMessages', 'Buscando pareja...');
  });

  // Chat iniciado
  socket.on('chatStart', ({ role }) => {
    chatActive = true;
    document.getElementById('strangerDot').className = 'dot online';
    document.getElementById('strangerLabel').textContent = 'Extraño';
    document.getElementById('msgInput').disabled = false;
    document.getElementById('sendBtn').disabled = false;
    document.getElementById('startBtn').disabled = true;
    document.getElementById('stopBtn').disabled = false;
    clearMessages();
    addSystemMsg('strangerMessages', '¡Conectado! Di hola 👋');
    addSystemMsg('yourMessages', '¡Conectado con un extraño!');
  });

  // Mensaje recibido
  socket.on('message', text => {
    addMsg('strangerMessages', 'stranger', text);
  });

  // Extraño escribiendo
  socket.on('strangerTyping', () => {
    document.getElementById('typingIndicator').textContent = 'El extraño está escribiendo...';
  });
  socket.on('strangerStopTyping', () => {
    document.getElementById('typingIndicator').textContent = '';
  });

  // Extraño se fue
  socket.on('strangerLeft', () => {
    chatActive = false;
    document.getElementById('strangerDot').className = 'dot';
    document.getElementById('strangerLabel').textContent = 'Extraño (desconectado)';
    document.getElementById('msgInput').disabled = true;
    document.getElementById('sendBtn').disabled = true;
    document.getElementById('startBtn').disabled = false;
    document.getElementById('stopBtn').disabled = true;
    document.getElementById('typingIndicator').textContent = '';
    addSystemMsg('strangerMessages', 'El extraño se desconectó. Haz clic en "Nuevo chat".');
    addSystemMsg('yourMessages', 'El extraño se desconectó.');
  });

  // --- Acciones del usuario ---
  function startChat() {
    clearMessages();
    document.getElementById('strangerMessages').innerHTML = '';
    document.getElementById('yourMessages').innerHTML = '';
    addSystemMsg('strangerMessages', 'Buscando...');
    socket.emit('findChat');
    document.getElementById('startBtn').disabled = true;
  }

  function leaveChat() {
    socket.emit('leaveChat');
    chatActive = false;
    document.getElementById('strangerDot').className = 'dot';
    document.getElementById('strangerLabel').textContent = 'Extraño (desconectado)';
    document.getElementById('msgInput').disabled = true;
    document.getElementById('sendBtn').disabled = true;
    document.getElementById('startBtn').disabled = false;
    document.getElementById('stopBtn').disabled = true;
    document.getElementById('typingIndicator').textContent = '';
    addSystemMsg('strangerMessages', 'Te desconectaste. Haz clic en "Nuevo chat".');
    addSystemMsg('yourMessages', 'Te desconectaste.');
  }

  function sendMessage() {
    const input = document.getElementById('msgInput');
    const text = input.value.trim();
    if (!text || !chatActive) return;
    socket.emit('message', text);
    addMsg('yourMessages', 'you', text);
    // Mirror en panel del extraño
    const d = document.createElement('div');
    d.className = 'msg you';
    d.innerHTML = `<div class="msg-label">Tú</div>${esc(text)}`;
    document.getElementById('strangerMessages').appendChild(d);
    scrollBottom('strangerMessages');
    input.value = '';
    socket.emit('stopTyping');
  }

  function handleKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  }

  function onTyping() {
    if (!chatActive) return;
    socket.emit('typing');
    clearTimeout(typingTimer);
    typingTimer = setTimeout(() => socket.emit('stopTyping'), 1500);
  }

  // --- Helpers ---
  function addMsg(panelId, type, text) {
    const panel = document.getElementById(panelId);
    const div = document.createElement('div');
    div.className = `msg ${type}`;
    const label = type === 'you' ? 'Tú' : 'Extraño';
    div.innerHTML = `<div class="msg-label">${label}</div>${esc(text)}`;
    panel.appendChild(div);
    scrollBottom(panelId);
  }
  function addSystemMsg(panelId, text) {
    const panel = document.getElementById(panelId);
    const div = document.createElement('div');
    div.className = 'msg system';
    div.textContent = text;
    panel.appendChild(div);
    scrollBottom(panelId);
  }
  function clearMessages() {
    document.getElementById('strangerMessages').innerHTML = '';
    document.getElementById('yourMessages').innerHTML = '';
  }
  function scrollBottom(id) {
    const el = document.getElementById(id);
    el.scrollTop = el.scrollHeight;
  }
  function esc(t) {
    return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // Interests
  const interests = [];
  function addInterest(e) {
    if (e.key !== 'Enter') return;
    const val = e.target.value.trim();
    if (!val || interests.length >= 5) { e.target.value=''; return; }
    interests.push(val);
    renderTags();
    e.target.value = '';
  }
  function removeTag(i) { interests.splice(i,1); renderTags(); }
  function renderTags() {
    document.getElementById('tagsContainer').innerHTML =
      interests.map((t,i)=>`<span class="tag">${t}<span class="x" onclick="removeTag(${i})">×</span></span>`).join('');
  }
</script>
</body>
</html>
